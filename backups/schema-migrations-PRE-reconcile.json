            "ALTER TABLE \"public\".\"agent_tools\" OWNER TO \"postgres\"",
            "CREATE TABLE IF NOT EXISTS \"public\".\"agents\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"name\" \"text\" NOT NULL,\n    \"display_name\" \"text\" NOT NULL,\n    \"role\" \"text\" NOT NULL,\n    \"department_id\" \"uuid\",\n    \"reports_to\" \"uuid\",\n    \"identity_source\" \"text\" DEFAULT 'imported'::\"text\" NOT NULL,\n    \"identity_content\" \"text\" NOT NULL,\n    \"model\" \"text\" DEFAULT 'claude-sonnet'::\"text\" NOT NULL,\n    \"status\" \"text\" DEFAULT 'active'::\"text\" NOT NULL,\n    \"created_at\" timestamp with time zone DEFAULT \"now\"(),\n    \"updated_at\" timestamp with time zone DEFAULT \"now\"(),\n    \"department\" \"text\",\n    \"is_active\" boolean DEFAULT true NOT NULL,\n    \"phase\" \"text\",\n    CONSTRAINT \"agents_model_check\" CHECK ((\"model\" = ANY (ARRAY['claude-haiku'::\"text\", 'claude-sonnet'::\"text\", 'claude-opus'::\"text\", 'claude-haiku-4-5-20251001'::\"text\", 'claude-sonnet-4-6'::\"text\", 'claude-opus-4-6'::\"text\", 'claude-opus-4-7'::\"text\"]))),\n    CONSTRAINT \"agents_role_check\" CHECK ((\"role\" = ANY (ARRAY['gerente_general'::\"text\", 'jefe_departamento'::\"text\", 'empleado'::\"text\", 'transversal'::\"text\"]))),\n    CONSTRAINT \"agents_status_check\" CHECK ((\"status\" = ANY (ARRAY['active'::\"text\", 'inactive'::\"text\", 'pending'::\"text\"])))\n)",
            "ALTER TABLE \"public\".\"agents\" OWNER TO \"postgres\"",
            "CREATE TABLE IF NOT EXISTS \"public\".\"agents_log\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"agent_name\" \"text\" NOT NULL,\n    \"action\" \"text\" NOT NULL,\n    \"input\" \"jsonb\" DEFAULT '{}'::\"jsonb\",\n    \"output\" \"jsonb\" DEFAULT '{}'::\"jsonb\",\n    \"status\" \"text\" NOT NULL,\n    \"duration_ms\" integer DEFAULT 0,\n    \"cost_usd\" numeric(8,4) DEFAULT 0,\n    \"created_at\" timestamp with time zone DEFAULT \"now\"(),\n    CONSTRAINT \"agents_log_status_check\" CHECK ((\"status\" = ANY (ARRAY['success'::\"text\", 'error'::\"text\", 'timeout'::\"text\"])))\n)",
