            "CREATE TABLE IF NOT EXISTS \"public\".\"agent_health_metrics\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"agent_slug\" \"text\" NOT NULL,\n    \"latency_p50_ms\" integer,\n    \"latency_p95_ms\" integer,\n    \"latency_p99_ms\" integer,\n    \"error_rate\" numeric,\n    \"measured_at\" timestamp with time zone DEFAULT \"now\"()\n)",
            "ALTER TABLE \"public\".\"agent_health_metrics\" OWNER TO \"postgres\"",
            "CREATE TABLE IF NOT EXISTS \"public\".\"agent_image_generations\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"client_id\" \"text\",\n    \"agent_slug\" \"text\",\n    \"prompt\" \"text\" NOT NULL,\n    \"revised_prompt\" \"text\",\n    \"storage_path\" \"text\",\n    \"image_url\" \"text\",\n    \"size\" \"text\" DEFAULT '1024x1024'::\"text\" NOT NULL,\n    \"model\" \"text\" DEFAULT 'gpt-image-1'::\"text\" NOT NULL,\n    \"cost_usd\" numeric(10,6) DEFAULT 0 NOT NULL,\n    \"status\" \"text\" DEFAULT 'completed'::\"text\" NOT NULL,\n    \"error_message\" \"text\",\n    \"raw_response\" \"jsonb\",\n    \"caller\" \"text\",\n    \"created_at\" timestamp with time zone DEFAULT \"now\"() NOT NULL,\n    CONSTRAINT \"agent_image_generations_status_check\" CHECK ((\"status\" = ANY (ARRAY['completed'::\"text\", 'failed'::\"text\"])))\n)",
            "ALTER TABLE \"public\".\"agent_image_generations\" OWNER TO \"postgres\"",
            "COMMENT ON TABLE \"public\".\"agent_image_generations\" IS 'GPT Image (gpt-image-1) generation log. Caller: POST /api/images/generate. Sprint #6 Brazo 1. client_id is TEXT not FK to mirror agent_invocations and let the multi-path resolver (Fix 8b/8c) populate it without breakage.'",
            "CREATE TABLE IF NOT EXISTS \"public\".\"agent_improvement_proposals\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"meta_agent_run_id\" \"uuid\" NOT NULL,\n    \"agent_name\" \"text\" NOT NULL,\n    \"agent_id\" \"uuid\",\n    \"proposal_type\" \"text\" NOT NULL,\n    \"title\" \"text\" NOT NULL,\n    \"rationale\" \"text\" NOT NULL,\n    \"current_value\" \"text\",\n    \"proposed_value\" \"text\",\n    \"expected_impact\" \"text\",\n    \"pattern_id\" \"text\",\n    \"supporting_outcomes\" \"uuid\"[] DEFAULT '{}'::\"uuid\"[],\n    \"confidence_score\" numeric(3,2),\n    \"status\" \"text\" DEFAULT 'pending'::\"text\" NOT NULL,\n    \"reviewed_by\" \"text\",\n    \"review_notes\" \"text\",\n    \"reviewed_at\" timestamp with time zone,\n    \"applied_at\" timestamp with time zone,\n    \"priority\" \"text\" DEFAULT 'medium'::\"text\",\n    \"created_at\" timestamp with time zone DEFAULT \"now\"() NOT NULL,\n    CONSTRAINT \"agent_improvement_proposals_confidence_score_check\" CHECK (((\"confidence_score\" IS NULL) OR ((\"confidence_score\" \u003e= (0)::numeric) AND (\"confidence_score\" \u003c= (1)::numeric)))),\n    CONSTRAINT \"agent_improvement_proposals_priority_check\" CHECK ((\"priority\" = ANY (ARRAY['low'::\"text\", 'medium'::\"text\", 'high'::\"text\", 'critical'::\"text\"]))),\n    CONSTRAINT \"agent_improvement_proposals_proposal_type_check\" CHECK ((\"proposal_type\" = ANY (ARRAY['identity_update'::\"text\", 'skill_adjustment'::\"text\", 'model_change'::\"text\", 'workflow_change'::\"text\", 'parameter_tuning'::\"text\", 'retirement'::\"text\"]))),\n    CONSTRAINT \"agent_improvement_proposals_status_check\" CHECK ((\"status\" = ANY (ARRAY['pending'::\"text\", 'approved'::\"text\", 'rejected'::\"text\", 'deferred'::\"text\", 'applied'::\"text\"])))\n)",
            "ALTER TABLE \"public\".\"agent_improvement_proposals\" OWNER TO \"postgres\"",
            "CREATE TABLE IF NOT EXISTS \"public\".\"agent_insights\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"client_id\" \"text\",\n    \"insight_type\" \"text\" NOT NULL,\n    \"payload\" \"jsonb\" NOT NULL,\n    \"source\" \"text\",\n    \"confidence\" numeric(4,3),\n    \"evidence\" \"text\"[] DEFAULT ARRAY[]::\"text\"[],\n    \"agent_slug\" \"text\",\n    \"request_id\" \"text\",\n    \"created_at\" timestamp with time zone DEFAULT \"now\"() NOT NULL,\n    CONSTRAINT \"agent_insights_confidence_check\" CHECK (((\"confidence\" IS NULL) OR ((\"confidence\" \u003e= (0)::numeric) AND (\"confidence\" \u003c= (1)::numeric))))\n)",
            "ALTER TABLE \"public\".\"agent_insights\" OWNER TO \"postgres\"",
            "CREATE TABLE IF NOT EXISTS \"public\".\"agent_invocations\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"session_id\" \"text\" NOT NULL,\n    \"agent_id\" \"text\" NOT NULL,\n    \"agent_name\" \"text\",\n    \"command\" \"text\",\n    \"task_id\" \"text\",\n    \"workflow_id\" \"text\",\n    \"workflow_execution_id\" \"text\",\n    \"client_id\" \"text\",\n    \"journey_id\" \"text\",\n    \"model\" \"text\",\n    \"started_at\" timestamp with time zone NOT NULL,\n    \"ended_at\" timestamp with time zone,\n    \"duration_ms\" integer GENERATED ALWAYS AS (\nCASE\n    WHEN (\"ended_at\" IS NULL) THEN NULL::integer\n    ELSE ((EXTRACT(epoch FROM (\"ended_at\" - \"started_at\")) * (1000)::numeric))::integer\nEND) STORED,\n    \"cost_usd\" numeric(12,6),\n    \"tokens_input\" integer,\n    \"tokens_output\" integer,\n    \"tokens_cache_read\" integer,\n    \"tokens_cache_creation\" integer,\n    \"num_turns\" integer,\n    \"status\" \"text\" NOT NULL,\n    \"exit_code\" integer,\n    \"error_message\" \"text\",\n    \"metadata\" \"jsonb\" DEFAULT '{}'::\"jsonb\",\n    \"created_at\" timestamp with time zone DEFAULT \"clock_timestamp\"() NOT NULL,\n    \"system_prompt\" \"text\",\n    \"input_summary\" \"text\",\n    \"output_summary\" \"text\",\n    CONSTRAINT \"agent_invocations_status_check\" CHECK ((\"status\" = ANY (ARRAY['running'::\"text\", 'completed'::\"text\", 'failed'::\"text\", 'timeout'::\"text\"])))\n)",
            "ALTER TABLE \"public\".\"agent_invocations\" OWNER TO \"postgres\"",
            "COMMENT ON COLUMN \"public\".\"agent_invocations\".\"system_prompt\" IS 'Sprint 7.5 B6 · exact system prompt sent to the model on this invocation. NULL for pre-2026-05-22 rows (predates instrumentation). Used to audit Client Brain enrichment + agent identity drift retroactively.'",
            "COMMENT ON COLUMN \"public\".\"agent_invocations\".\"input_summary\" IS 'Sprint 8D · truncated input prompt summary · max 2000 chars + ellipsis · canonical forensics deep self-contained · NULL para historic rows pre-migration'",
            "COMMENT ON COLUMN \"public\".\"agent_invocations\".\"output_summary\" IS 'Sprint 8D · truncated output response summary · max 2000 chars + ellipsis · canonical forensics deep self-contained · NULL para historic rows pre-migration'",
            "CREATE MATERIALIZED VIEW \"public\".\"agent_invocations_daily_rollup\" AS\n SELECT (\"date_trunc\"('day'::\"text\", (\"started_at\" AT TIME ZONE 'UTC'::\"text\")))::\"date\" AS \"day\",\n    \"agent_id\",\n    COALESCE(\"model\", 'unknown'::\"text\") AS \"model\",\n    \"count\"(*) AS \"invocations_count\",\n    \"count\"(*) FILTER (WHERE (\"status\" = 'completed'::\"text\")) AS \"success_count\",\n    \"count\"(*) FILTER (WHERE (\"status\" = 'failed'::\"text\")) AS \"error_count\",\n    \"count\"(*) FILTER (WHERE (\"status\" = 'timeout'::\"text\")) AS \"timeout_count\",\n    \"round\"(COALESCE(\"sum\"(\"cost_usd\"), (0)::numeric), 4) AS \"total_cost_usd\",\n    \"round\"(COALESCE(\"avg\"(\"cost_usd\"), (0)::numeric), 6) AS \"avg_cost_usd\",\n    \"round\"((COALESCE(\"percentile_cont\"((0.50)::double precision) WITHIN GROUP (ORDER BY ((\"cost_usd\")::double precision)), (0)::double precision))::numeric, 6) AS \"p50_cost_usd\",\n    \"round\"((COALESCE(\"percentile_cont\"((0.95)::double precision) WITHIN GROUP (ORDER BY ((\"cost_usd\")::double precision)), (0)::double precision))::numeric, 6) AS \"p95_cost_usd\",\n    \"round\"((COALESCE(\"percentile_cont\"((0.99)::double precision) WITHIN GROUP (ORDER BY ((\"cost_usd\")::double precision)), (0)::double precision))::numeric, 6) AS \"p99_cost_usd\",\n    COALESCE(\"sum\"(\"tokens_input\"), (0)::bigint) AS \"total_tokens_input\",\n    COALESCE(\"sum\"(\"tokens_output\"), (0)::bigint) AS \"total_tokens_output\",\n    COALESCE(\"sum\"(\"tokens_cache_read\"), (0)::bigint) AS \"total_tokens_cache_read\",\n    COALESCE(\"sum\"(\"tokens_cache_creation\"), (0)::bigint) AS \"total_tokens_cache_creation\",\n    (\"round\"(COALESCE(\"avg\"(\"duration_ms\"), (0)::numeric), 0))::bigint AS \"avg_duration_ms\",\n    (\"round\"((COALESCE(\"percentile_cont\"((0.50)::double precision) WITHIN GROUP (ORDER BY ((\"duration_ms\")::double precision)), (0)::double precision))::numeric, 0))::bigint AS \"p50_duration_ms\",\n    (\"round\"((COALESCE(\"percentile_cont\"((0.95)::double precision) WITHIN GROUP (ORDER BY ((\"duration_ms\")::double precision)), (0)::double precision))::numeric, 0))::bigint AS \"p95_duration_ms\",\n    (\"round\"((COALESCE(\"percentile_cont\"((0.99)::double precision) WITHIN GROUP (ORDER BY ((\"duration_ms\")::double precision)), (0)::double precision))::numeric, 0))::bigint AS \"p99_duration_ms\",\n    (COALESCE(\"max\"(\"duration_ms\"), 0))::bigint AS \"max_duration_ms\",\n    \"min\"(\"started_at\") AS \"first_session_at\",\n    \"max\"(\"started_at\") AS \"last_session_at\",\n    \"clock_timestamp\"() AS \"refreshed_at\"\n   FROM \"public\".\"agent_invocations\"\n  GROUP BY ((\"date_trunc\"('day'::\"text\", (\"started_at\" AT TIME ZONE 'UTC'::\"text\")))::\"date\"), \"agent_id\", COALESCE(\"model\", 'unknown'::\"text\")\n  WITH NO DATA",
            "ALTER MATERIALIZED VIEW \"public\".\"agent_invocations_daily_rollup\" OWNER TO \"postgres\"",
            "CREATE TABLE IF NOT EXISTS \"public\".\"agent_outcomes\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"client_id\" \"uuid\",\n    \"agent_name\" \"text\",\n    \"task_type\" \"text\",\n    \"task_input\" \"text\",\n    \"output_summary\" \"text\",\n    \"output_id\" \"uuid\",\n    \"final_verdict\" \"text\",\n    \"human_feedback\" \"text\",\n    \"edited_delta\" \"text\",\n    \"performance_metrics\" \"jsonb\" DEFAULT '{}'::\"jsonb\",\n    \"processed_by_meta_agent\" boolean DEFAULT false,\n    \"meta_agent_run_id\" \"uuid\",\n    \"created_at\" timestamp with time zone DEFAULT \"now\"() NOT NULL,\n    \"pipeline_id\" \"uuid\",\n    \"step_index\" integer,\n    \"step_name\" \"text\",\n    \"cost_usd\" numeric(10,4) DEFAULT 0,\n    \"duration_ms\" integer,\n    \"tokens_used\" integer,\n    \"agent_slug\" \"text\",\n    \"agent_log_id\" \"uuid\",\n    \"task_kind\" \"text\",\n    \"reference_id\" \"uuid\",\n    \"rating\" integer,\n    \"hitl_decision\" \"text\",\n    \"business_outcome\" \"jsonb\" DEFAULT '{}'::\"jsonb\",\n    \"notes\" \"text\",\n    \"task_id\" \"text\",\n    \"request_id\" \"text\",\n    \"input\" \"text\",\n    \"output\" \"text\",\n    \"input_tokens\" integer,\n    \"output_tokens\" integer,\n    \"latency_ms\" integer,\n    \"success\" boolean DEFAULT true NOT NULL,\n    \"error\" \"text\",\n    \"model\" \"text\",\n    CONSTRAINT \"agent_outcomes_final_verdict_check\" CHECK ((\"final_verdict\" = ANY (ARRAY['approved'::\"text\", 'rejected'::\"text\", 'edited'::\"text\", 'escalated'::\"text\"])))\n)",
            "ALTER TABLE \"public\".\"agent_outcomes\" OWNER TO \"postgres\"",
            "CREATE TABLE IF NOT EXISTS \"public\".\"agent_routing_log\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"request_id\" \"text\" NOT NULL,\n    \"client_id\" \"text\",\n    \"original_request\" \"text\" NOT NULL,\n    \"classification_type\" \"text\" NOT NULL,\n    \"assigned_agents\" \"jsonb\" DEFAULT '[]'::\"jsonb\" NOT NULL,\n    \"complexity\" \"text\",\n    \"confidence\" numeric(3,2),\n    \"status\" \"text\" DEFAULT 'routed'::\"text\" NOT NULL,\n    \"routed_at\" timestamp with time zone DEFAULT \"now\"() NOT NULL,\n    \"completed_at\" timestamp with time zone,\n    CONSTRAINT \"agent_routing_log_classification_type_check\" CHECK ((\"classification_type\" = ANY (ARRAY['depth-first'::\"text\", 'breadth-first'::\"text\", 'straightforward'::\"text\"]))),\n    CONSTRAINT \"agent_routing_log_complexity_check\" CHECK ((\"complexity\" = ANY (ARRAY['low'::\"text\", 'medium'::\"text\", 'high'::\"text\", 'critical'::\"text\"]))),\n    CONSTRAINT \"agent_routing_log_status_check\" CHECK ((\"status\" = ANY (ARRAY['routed'::\"text\", 'completed'::\"text\", 'failed'::\"text\", 'escalated_to_hitl'::\"text\"])))\n)",
