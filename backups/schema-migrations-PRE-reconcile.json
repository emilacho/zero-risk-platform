            "CREATE OR REPLACE FUNCTION \"naufrago\".\"subscribers_touch_updated_at\"() RETURNS \"trigger\"\n    LANGUAGE \"plpgsql\"\n    AS $$\nbegin\n  new.updated_at := now();\n  return new;\nend;\n$$",
