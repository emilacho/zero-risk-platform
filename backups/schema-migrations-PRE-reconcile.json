            "ALTER TABLE \"public\".\"uptime_incidents\" OWNER TO \"postgres\"",
            "CREATE OR REPLACE VIEW \"public\".\"v_active_pipelines\" AS\n SELECT \"pe\".\"id\" AS \"pipeline_id\",\n    \"pe\".\"objective\",\n    \"pe\".\"status\" AS \"pipeline_status\",\n    \"pe\".\"current_step_index\",\n    \"pe\".\"created_at\" AS \"pipeline_started\",\n    \"ps\".\"step_name\" AS \"current_step_name\",\n    \"ps\".\"step_display_name\" AS \"current_step_display\",\n    \"ps\".\"status\" AS \"step_status\",\n    \"ps\".\"agent_name\",\n    (\"pe\".\"total_input_tokens\" + \"pe\".\"total_output_tokens\") AS \"total_tokens\",\n    \"pe\".\"total_cost_usd\",\n    \"c\".\"name\" AS \"client_name\"\n   FROM ((\"public\".\"pipeline_executions\" \"pe\"\n     LEFT JOIN \"public\".\"pipeline_steps\" \"ps\" ON (((\"ps\".\"pipeline_id\" = \"pe\".\"id\") AND (\"ps\".\"step_index\" = \"pe\".\"current_step_index\"))))\n     LEFT JOIN \"public\".\"clients\" \"c\" ON ((\"c\".\"id\" = \"pe\".\"client_id\")))\n  WHERE (\"pe\".\"status\" = ANY (ARRAY['running'::\"text\", 'paused_hitl'::\"text\", 'pending'::\"text\"]))\n  ORDER BY \"pe\".\"created_at\" DESC",
            "ALTER VIEW \"public\".\"v_active_pipelines\" OWNER TO \"postgres\"",
            "CREATE OR REPLACE VIEW \"public\".\"v_agent_scorecards\" AS\n SELECT \"agent_name\",\n    \"count\"(*) AS \"total_tasks\",\n    \"count\"(*) FILTER (WHERE (\"final_verdict\" = 'approved'::\"text\")) AS \"approved\",\n    \"count\"(*) FILTER (WHERE (\"final_verdict\" = 'rejected'::\"text\")) AS \"rejected\",\n    \"count\"(*) FILTER (WHERE (\"final_verdict\" = 'edited'::\"text\")) AS \"edited\",\n    \"round\"((((\"count\"(*) FILTER (WHERE (\"final_verdict\" = ANY (ARRAY['approved'::\"text\", 'edited'::\"text\"]))))::numeric / (NULLIF(\"count\"(*), 0))::numeric) * (100)::numeric), 1) AS \"approval_rate_pct\",\n    \"round\"(\"avg\"(\"cost_usd\"), 4) AS \"avg_cost\",\n    \"round\"((\"avg\"(\"duration_ms\") / (1000)::numeric), 1) AS \"avg_duration_sec\",\n    \"sum\"(\"cost_usd\") AS \"total_cost\",\n    \"max\"(\"created_at\") AS \"last_activity\"\n   FROM \"public\".\"agent_outcomes\" \"ao\"\n  WHERE (\"created_at\" \u003e= (\"now\"() - '30 days'::interval))\n  GROUP BY \"agent_name\"\n  ORDER BY (\"count\"(*)) DESC",
            "ALTER VIEW \"public\".\"v_agent_scorecards\" OWNER TO \"postgres\"",
            "CREATE OR REPLACE VIEW \"public\".\"v_hitl_inbox\" AS\n SELECT \"ps\".\"id\" AS \"step_id\",\n    \"pe\".\"id\" AS \"pipeline_id\",\n    \"pe\".\"objective\",\n    \"ps\".\"step_index\",\n    \"ps\".\"step_display_name\",\n    \"ps\".\"output_text\",\n    \"ps\".\"hitl_status\",\n    \"ps\".\"created_at\" AS \"submitted_at\",\n    \"c\".\"name\" AS \"client_name\",\n    \"pe\".\"created_by\"\n   FROM ((\"public\".\"pipeline_steps\" \"ps\"\n     JOIN \"public\".\"pipeline_executions\" \"pe\" ON ((\"pe\".\"id\" = \"ps\".\"pipeline_id\")))\n     LEFT JOIN \"public\".\"clients\" \"c\" ON ((\"c\".\"id\" = \"pe\".\"client_id\")))\n  WHERE ((\"ps\".\"hitl_required\" = true) AND (\"ps\".\"hitl_status\" = 'pending'::\"text\") AND (\"ps\".\"status\" = 'paused_hitl'::\"text\"))\n  ORDER BY \"ps\".\"created_at\"",
            "ALTER VIEW \"public\".\"v_hitl_inbox\" OWNER TO \"postgres\"",
            "CREATE OR REPLACE VIEW \"public\".\"v_pending_improvements\" AS\n SELECT \"aip\".\"id\",\n    \"aip\".\"agent_name\",\n    \"aip\".\"proposal_type\",\n    \"aip\".\"title\",\n    \"aip\".\"rationale\",\n    \"aip\".\"expected_impact\",\n    \"aip\".\"confidence_score\",\n    \"aip\".\"priority\",\n    \"aip\".\"status\",\n    \"mar\".\"executive_summary\" AS \"run_summary\",\n    \"aip\".\"created_at\"\n   FROM (\"public\".\"agent_improvement_proposals\" \"aip\"\n     JOIN \"public\".\"meta_agent_runs\" \"mar\" ON ((\"mar\".\"id\" = \"aip\".\"meta_agent_run_id\")))\n  WHERE (\"aip\".\"status\" = 'pending'::\"text\")\n  ORDER BY\n        CASE \"aip\".\"priority\"\n            WHEN 'critical'::\"text\" THEN 1\n            WHEN 'high'::\"text\" THEN 2\n            WHEN 'medium'::\"text\" THEN 3\n            WHEN 'low'::\"text\" THEN 4\n            ELSE NULL::integer\n        END, \"aip\".\"confidence_score\" DESC",
            "ALTER VIEW \"public\".\"v_pending_improvements\" OWNER TO \"postgres\"",
            "CREATE TABLE IF NOT EXISTS \"public\".\"websites\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"name\" \"text\" NOT NULL,\n    \"url\" \"text\" NOT NULL,\n    \"type\" \"text\" DEFAULT 'landing_page'::\"text\" NOT NULL,\n    \"status\" \"text\" DEFAULT 'draft'::\"text\" NOT NULL,\n    \"analytics\" \"jsonb\" DEFAULT '{}'::\"jsonb\",\n    \"created_at\" timestamp with time zone DEFAULT \"now\"(),\n    \"updated_at\" timestamp with time zone DEFAULT \"now\"(),\n    CONSTRAINT \"websites_status_check\" CHECK ((\"status\" = ANY (ARRAY['draft'::\"text\", 'published'::\"text\", 'archived'::\"text\"]))),\n    CONSTRAINT \"websites_type_check\" CHECK ((\"type\" = ANY (ARRAY['landing_page'::\"text\", 'main_site'::\"text\"])))\n)",
