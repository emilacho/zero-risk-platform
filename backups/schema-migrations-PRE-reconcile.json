            "CREATE OR REPLACE VIEW \"public\".\"active_journeys\" AS\n SELECT \"cjs\".\"id\",\n    \"cjs\".\"client_id\",\n    \"c\".\"name\" AS \"client_name\",\n    \"cjs\".\"journey\",\n    \"cjs\".\"current_stage\",\n    \"cjs\".\"status\",\n    \"cjs\".\"trigger_type\",\n    \"cjs\".\"trigger_source\",\n    \"cjs\".\"hitl_pending_count\",\n    \"cjs\".\"started_at\",\n    \"cjs\".\"updated_at\",\n    (EXTRACT(epoch FROM (\"now\"() - \"cjs\".\"started_at\")) / 3600.0) AS \"hours_active\"\n   FROM (\"public\".\"client_journey_state\" \"cjs\"\n     LEFT JOIN \"public\".\"clients\" \"c\" ON ((\"c\".\"id\" = \"cjs\".\"client_id\")))\n  WHERE (\"cjs\".\"status\" = ANY (ARRAY['initiated'::\"public\".\"journey_status\", 'active'::\"public\".\"journey_status\", 'paused_hitl'::\"public\".\"journey_status\"]))",
            "ALTER VIEW \"public\".\"active_journeys\" OWNER TO \"postgres\"",
            "CREATE TABLE IF NOT EXISTS \"public\".\"activities\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"client_id\" \"uuid\" NOT NULL,\n    \"subject_type\" \"text\" NOT NULL,\n    \"subject_id\" \"uuid\" NOT NULL,\n    \"kind\" \"text\" NOT NULL,\n    \"summary\" \"text\" NOT NULL,\n    \"body\" \"text\",\n    \"occurred_at\" timestamp with time zone DEFAULT \"now\"() NOT NULL,\n    \"agent_run_id\" \"uuid\",\n    \"metadata\" \"jsonb\" DEFAULT '{}'::\"jsonb\",\n    \"created_at\" timestamp with time zone DEFAULT \"now\"() NOT NULL,\n    \"updated_at\" timestamp with time zone DEFAULT \"now\"() NOT NULL,\n    CONSTRAINT \"activities_kind_check\" CHECK ((\"kind\" = ANY (ARRAY['call'::\"text\", 'email'::\"text\", 'meeting'::\"text\", 'note'::\"text\", 'task'::\"text\", 'agent_run'::\"text\", 'system_event'::\"text\", 'other'::\"text\"]))),\n    CONSTRAINT \"activities_subject_type_check\" CHECK ((\"subject_type\" = ANY (ARRAY['contact'::\"text\", 'company'::\"text\", 'deal'::\"text\", 'cliente'::\"text\"])))\n)",
            "ALTER TABLE \"public\".\"activities\" OWNER TO \"postgres\"",
            "COMMENT ON TABLE \"public\".\"activities\" IS 'Sprint 8C · time-series activity log per CRM subject. Polymorphic via (subject_type, subject_id) · subject NOT enforced via FK (rows can reference soft-deleted parents). Sources · sales rep manual entry · NEXUS Phase 7 hooks · agent runs.'",
            "COMMENT ON COLUMN \"public\".\"activities\".\"agent_run_id\" IS 'Optional FK to agent_invocations.id when the activity was generated by an agent run.'",
            "CREATE TABLE IF NOT EXISTS \"public\".\"ad_creative_refreshes\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"campaign_id\" \"text\" NOT NULL,\n    \"client_id\" \"text\" NOT NULL,\n    \"ad_id\" \"text\" NOT NULL,\n    \"fatigue_signals\" \"jsonb\" DEFAULT '{}'::\"jsonb\",\n    \"old_creative_metadata\" \"jsonb\",\n    \"new_creative_metadata\" \"jsonb\",\n    \"new_image_urls\" \"text\"[],\n    \"refresh_reason\" \"text\",\n    \"hitl_approved\" boolean,\n    \"deployed\" boolean DEFAULT false,\n    \"deployed_at\" timestamp with time zone,\n    \"created_at\" timestamp with time zone DEFAULT \"now\"() NOT NULL\n)",
            "ALTER TABLE \"public\".\"ad_creative_refreshes\" OWNER TO \"postgres\"",
            "CREATE TABLE IF NOT EXISTS \"public\".\"ad_performance_snapshots\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"client_id\" \"text\" NOT NULL,\n    \"platform\" \"text\" NOT NULL,\n    \"campaign_id\" \"text\" NOT NULL,\n    \"ad_id\" \"text\",\n    \"snapshot_date\" \"date\" NOT NULL,\n    \"tier\" \"text\",\n    \"impressions\" bigint,\n    \"clicks\" integer,\n    \"spend\" numeric(12,4),\n    \"conversions\" integer,\n    \"revenue\" numeric(12,4),\n    \"cpa\" numeric(10,4),\n    \"roas\" numeric(10,4),\n    \"ctr\" numeric(6,4),\n    \"cvr\" numeric(6,4),\n    \"frequency\" numeric(6,4),\n    \"quality_score\" integer,\n    \"anomaly_flags\" \"jsonb\" DEFAULT '[]'::\"jsonb\",\n    \"created_at\" timestamp with time zone DEFAULT \"now\"() NOT NULL,\n    CONSTRAINT \"ad_performance_snapshots_tier_check\" CHECK ((\"tier\" = ANY (ARRAY['beta'::\"text\", 'scaling'::\"text\", 'efficient'::\"text\", 'mature'::\"text\"])))\n)",
            "ALTER TABLE \"public\".\"ad_performance_snapshots\" OWNER TO \"postgres\"",
            "CREATE TABLE IF NOT EXISTS \"public\".\"agent_3d_generations\" (\n    \"id\" \"uuid\" DEFAULT \"gen_random_uuid\"() NOT NULL,\n    \"client_id\" \"text\",\n    \"agent_slug\" \"text\",\n    \"prompt\" \"text\" NOT NULL,\n    \"art_style\" \"text\" DEFAULT 'realistic'::\"text\" NOT NULL,\n    \"format\" \"text\" DEFAULT 'glb'::\"text\" NOT NULL,\n    \"type\" \"text\" DEFAULT 'object'::\"text\" NOT NULL,\n    \"meshy_task_id\" \"text\",\n    \"storage_path\" \"text\",\n    \"model_url\" \"text\",\n    \"thumbnail_url\" \"text\",\n    \"polycount\" integer,\n    \"model\" \"text\" DEFAULT 'meshy-6'::\"text\" NOT NULL,\n    \"cost_usd\" numeric(10,6) DEFAULT 0 NOT NULL,\n    \"duration_ms\" integer,\n    \"status\" \"text\" DEFAULT 'completed'::\"text\" NOT NULL,\n    \"error_message\" \"text\",\n    \"raw_response\" \"jsonb\",\n    \"caller\" \"text\",\n    \"created_at\" timestamp with time zone DEFAULT \"now\"() NOT NULL,\n    CONSTRAINT \"agent_3d_generations_art_style_check\" CHECK ((\"art_style\" = ANY (ARRAY['realistic'::\"text\", 'cartoon'::\"text\", 'low-poly'::\"text\", 'sculpture'::\"text\", 'pbr'::\"text\"]))),\n    CONSTRAINT \"agent_3d_generations_format_check\" CHECK ((\"format\" = ANY (ARRAY['glb'::\"text\", 'fbx'::\"text\", 'obj'::\"text\", 'usdz'::\"text\", 'mtl'::\"text\"]))),\n    CONSTRAINT \"agent_3d_generations_status_check\" CHECK ((\"status\" = ANY (ARRAY['completed'::\"text\", 'failed'::\"text\", 'timeout'::\"text\"]))),\n    CONSTRAINT \"agent_3d_generations_type_check\" CHECK ((\"type\" = ANY (ARRAY['object'::\"text\", 'character'::\"text\", 'environment'::\"text\"])))\n)",
            "ALTER TABLE \"public\".\"agent_3d_generations\" OWNER TO \"postgres\"",
