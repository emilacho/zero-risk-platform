    },
    {
      "parameters": {
        "jsCode": "// Normalize outcome data\nconst body = $input.first().json.body;\nconst { agent_slug, task_id, input_text, output_text, tokens_used, latency_ms, success, error } = body;\n\nif (!agent_slug || !task_id) {\n  throw new Error('Missing required: agent_slug, task_id');\n}\n\nconst outcome = {\n  agent_slug,\n  task_id,\n  input: input_text || '',\n  output: output_text || '',\n  tokens_used: tokens_used || 0,\n  latency_ms: latency_ms || 0,\n  success: success !== undefined ? success : true,\n  error: error || null,\n  created_at: new Date().toISOString()\n};\n\nreturn [{ json: outcome }];"
      },
      "id": "c55c8bd9-0d61-4d50-a351-f2881144227e",
      "name": "Normalize Outcome",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ]
    },
    {
