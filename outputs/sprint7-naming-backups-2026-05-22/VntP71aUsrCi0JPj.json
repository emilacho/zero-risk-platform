        "specifyBody": "json",
        "jsonBody": "={\n  \"channel\": \"#ops-critical\",\n  \"text\": \"?? P0 ERROR - {{ $json.issue_title }}\",\n  \"blocks\": [\n    {\n      \"type\": \"header\",\n      \"text\": { \"type\": \"plain_text\", \"text\": \"?? PRODUCTION P0 ALERT\" }\n    },\n    {\n      \"type\": \"section\",\n      \"fields\": [\n        { \"type\": \"mrkdwn\", \"text\": \"*Error:*\\n{{ $json.issue_title }}\" },\n        { \"type\": \"mrkdwn\", \"text\": \"*Type:*\\n{{ $json.exception_type }}\" },\n        { \"type\": \"mrkdwn\", \"text\": \"*Environment:*\\n{{ $json.environment }}\" },\n        { \"type\": \"mrkdwn\", \"text\": \"*Time:*\\n{{ $json.timestamp }}\" }\n      ]\n    },\n    {\n      \"type\": \"actions\",\n      \"elements\": [\n        { \"type\": \"button\", \"text\": { \"type\": \"plain_text\", \"text\": \"View in Sentry\" }, \"url\": \"{{ $json.url }}\" }\n      ]\n    }\n  ]\n}",
        "options": {
          "response": {
