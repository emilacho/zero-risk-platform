    {
      "parameters": {
        "jsCode": "// Classify Sentry issue severity based on error type and environment\nconst payload = $input.first().json;\nconst event = payload.data?.event || {};\nconst issue = payload.data?.issue || {};\nconst environment = event.environment || 'production';\nconst exceptionType = event.tags?.find(t => t[0] === 'exception')?.['1'] || '';\nconst level = event.level || 'error';\nconst isProduction = environment === 'production';\nconst is500Error = exceptionType.includes('500') || level === 'fatal';\nconst isAuthFailure = exceptionType.includes('AuthError') || exceptionType.includes('Unauthorized');\nconst isClientFacingRegression = exceptionType.includes('TypeError') || exceptionType.includes('ReferenceError');\n\nlet severity = 'P2'; // default\nlet shouldAlert = false;\n\nif (isProduction) {\n  if (is500Error || isAuthFailure) {\n    severity = 'P0';\n    shouldAlert = true;\n  } else if (isClientFacingRegression) {\n    severity = 'P1';\n    shouldAlert = true;\n  }\n} else {\n  severity = 'P2';\n}\n\nreturn [{\n  json: {\n    issue_id: issue.id,\n    issue_title: issue.title,\n    fingerprint: issue.metadata?.value || issue.id,\n    severity,\n    environment,\n    exception_type: exceptionType,\n    level,\n    timestamp: event.timestamp,\n    url: issue.permalink,\n    should_alert: shouldAlert,\n    message: event.message || issue.title,\n    raw_payload: payload\n  }\n}];"
      },
