# Constrain pnpm to install only the glibc variant of native packages.
#
# Railway containers run on standard Linux (Debian/Ubuntu base · glibc).
# Without this, pnpm pulls BOTH linux-x64-glibc AND linux-x64-musl variants
# for @anthropic-ai/claude-agent-sdk; the SDK's runtime resolver then can
# pick the musl variant and fail with "binary not found" because the musl
# binary won't run on glibc.
#
# Mirror of zero-risk-platform/.npmrc at the repo root (defense-in-depth
# for the Vercel side); Railway builds from this directory (services/
# agent-runner/) and does NOT inherit the root .npmrc, so we need a local
# copy here.
supportedArchitectures.os[]=linux
supportedArchitectures.cpu[]=x64
supportedArchitectures.libc[]=glibc
