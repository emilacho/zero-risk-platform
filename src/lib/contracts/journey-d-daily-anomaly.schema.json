{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zero-risk-platform.vercel.app/schemas/journey-d-daily-anomaly.schema.json",
  "title": "Journey D — Daily Optimization Anomaly",
  "description": "Daily optimization anomaly detection from optimization-agent. If severity=high, escalate to jefe-marketing immediately",
  "type": "object",
  "properties": {
    "anomalies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["roas_drop", "creative_fatigue", "audience_saturation", "conversion_drop"],
            "description": "Type of anomaly detected"
          },
          "metric_value": {
            "type": "number",
            "description": "Current metric value"
          },
          "threshold": {
            "type": "number",
            "description": "Alert threshold that was breached"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "med", "high"],
            "description": "Severity level (low/med/high)"
          }
        },
        "required": ["type", "metric_value", "threshold", "severity"]
      }
    },
    "severity": {
      "type": "string",
      "enum": ["low", "med", "high"],
      "description": "Overall severity (high = escalate immediately)"
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10,
        "maxLength": 300
      },
      "description": "Recommended actions"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of anomaly detection"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    }
  },
  "required": ["anomalies", "severity", "recommendations", "timestamp", "schema_version"],
  "additionalProperties": false
}
