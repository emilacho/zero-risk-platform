{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "metrics-fetch",
  "type": "object",
  "title": "POST /api/metrics/fetch",
  "description": "Generic metric reader. Caller: `Zero Risk - Creative Performance Learner`. Closes W15-D-21. POST so callers can send a flexible filter body.",
  "additionalProperties": true,
  "required": ["metric_names"],
  "properties": {
    "client_id": { "type": ["string", "null"], "maxLength": 200 },
    "metric_names": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": { "type": "string", "minLength": 1, "maxLength": 200 }
    },
    "since_days": { "type": ["integer", "null"], "minimum": 1, "maximum": 365 },
    "until": { "type": ["string", "null"], "format": "date-time" },
    "platform": { "type": ["string", "null"], "maxLength": 50 },
    "limit": { "type": ["integer", "null"], "minimum": 1, "maximum": 1000 }
  }
}
