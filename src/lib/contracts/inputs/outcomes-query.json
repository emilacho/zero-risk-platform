{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "outcomes-query",
  "type": "object",
  "title": "POST /api/outcomes/query",
  "description": "Query past agent outcomes for the Creative Performance Learner. Permissive filter shape · all fields optional. Caller: `Zero Risk — Creative Performance Learner`. Closes W15-D-24.",
  "additionalProperties": true,
  "properties": {
    "client_id": { "type": ["string", "null"], "maxLength": 200 },
    "agent_slug": { "type": ["string", "null"], "maxLength": 100 },
    "outcome_type": {
      "type": ["string", "null"],
      "enum": ["success", "failure", "partial", "deferred", null]
    },
    "since_days": { "type": ["integer", "null"], "minimum": 1, "maximum": 365 },
    "until": { "type": ["string", "null"], "format": "date-time" },
    "limit": { "type": ["integer", "null"], "minimum": 1, "maximum": 500 },
    "offset": { "type": ["integer", "null"], "minimum": 0 },
    "campaign_id": { "type": ["string", "null"], "maxLength": 200 },
    "min_confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "maxLength": 100 },
      "maxItems": 50
    }
  }
}
