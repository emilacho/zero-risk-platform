{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "testing-fetch-test-results",
  "type": "object",
  "title": "POST /api/testing/fetch-test-results",
  "description": "Read recent CRO/incrementality results. Caller: `Zero Risk - Incrementality Test Runner (15min + Webhook)`. Closes W15-D-30. POST so callers can send a flexible filter body.",
  "additionalProperties": true,
  "required": [],
  "properties": {
    "client_id": { "type": ["string", "null"], "maxLength": 200 },
    "experiment_id": { "type": ["string", "null"], "maxLength": 200 },
    "test_type": { "type": ["string", "null"], "enum": ["cro", "incrementality", "subject_line", "creative", null] },
    "status": { "type": ["string", "null"], "enum": ["running", "completed", "stopped", "queued", null] },
    "since_hours": { "type": ["integer", "null"], "minimum": 1, "maximum": 8760 },
    "limit": { "type": ["integer", "null"], "minimum": 1, "maximum": 500 }
  }
}
