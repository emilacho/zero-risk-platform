{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-outcomes-write",
  "type": "object",
  "title": "POST /api/agent-outcomes/write",
  "required": ["agent_slug"],
  "additionalProperties": true,
  "properties": {
    "agent_slug": { "type": "string", "minLength": 1, "maxLength": 100 },
    "task_id": { "type": ["string", "null"], "maxLength": 200 },
    "request_id": { "type": ["string", "null"], "maxLength": 200 },
    "client_id": { "type": ["string", "null"], "maxLength": 100 },
    "input": {},
    "output": {},
    "tokens_used": { "type": ["number", "null"], "minimum": 0 },
    "duration_ms": { "type": ["number", "null"], "minimum": 0 },
    "outcome": {
      "type": ["string", "null"],
      "enum": ["success", "failure", "partial", "deferred", null]
    },
    "metadata": { "type": ["object", "null"] }
  }
}
