{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "leads-create",
  "type": "object",
  "title": "POST /api/leads (lead intake)",
  "additionalProperties": true,
  "properties": {
    "name": { "type": ["string", "null"], "maxLength": 200 },
    "email": { "type": ["string", "null"], "maxLength": 200 },
    "phone": { "type": ["string", "null"], "maxLength": 30 },
    "source": { "type": ["string", "null"], "maxLength": 100 },
    "status": { "type": ["string", "null"], "maxLength": 50 },
    "assigned_to": { "type": ["string", "null"], "maxLength": 100 },
    "notes": { "type": ["string", "null"], "maxLength": 2000 },
    "campaign_id": { "type": ["string", "null"], "maxLength": 200 },
    "metadata": { "type": ["object", "null"] }
  }
}
