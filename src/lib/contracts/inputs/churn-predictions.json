{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "churn-predictions",
  "type": "object",
  "title": "POST /api/churn-predictions",
  "description": "Write-path for ML churn-prediction output. Caller: `Zero Risk - Churn Prediction 90d Pre-Renewal`. Closes W15-D-07.",
  "additionalProperties": true,
  "required": ["client_id", "churn_probability"],
  "properties": {
    "client_id": { "type": "string", "minLength": 1, "maxLength": 200 },
    "predicted_at": { "type": ["string", "null"], "format": "date-time" },
    "churn_probability": { "type": "number", "minimum": 0, "maximum": 1 },
    "prediction_window_days": { "type": ["integer", "null"], "minimum": 1, "maximum": 365 },
    "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "top_factors": {
      "type": ["array", "null"],
      "maxItems": 20,
      "items": { "type": "string", "maxLength": 200 }
    },
    "model_version": { "type": ["string", "null"], "maxLength": 100 },
    "context": { "type": ["object", "null"] }
  }
}
