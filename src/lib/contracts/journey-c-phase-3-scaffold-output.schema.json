{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zero-risk-platform.vercel.app/schemas/journey-c-phase-3-scaffold-output.schema.json",
  "title": "Journey C Phase 3 — Scaffold Output (Task Breakdown)",
  "description": "Breakdown of campaign into sub-tasks with sequencing, dependencies, and effort estimation",
  "type": "object",
  "properties": {
    "sub_tasks": {
      "type": "array",
      "minItems": 5,
      "description": "Array of discrete sub-tasks to execute campaign build-out (min 5 required)",
      "items": {
        "type": "object",
        "properties": {
          "agent": {
            "type": "string",
            "minLength": 5,
            "maxLength": 100,
            "description": "Agent responsible for this sub-task (e.g., 'jefe-creative', 'media-buyer', 'seo-specialist')"
          },
          "task_description": {
            "type": "string",
            "minLength": 20,
            "maxLength": 500,
            "description": "Clear description of what this sub-task delivers"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of other task IDs or names that must complete before this task"
          },
          "estimated_effort_hours": {
            "type": "number",
            "minimum": 0.5,
            "maximum": 200,
            "description": "Estimated hours to complete (total across all tasks must be >= 20)"
          }
        },
        "required": ["agent", "task_description", "dependencies", "estimated_effort_hours"],
        "additionalProperties": false
      }
    },
    "task_sequence": {
      "type": "array",
      "minItems": 5,
      "description": "Ordered list of task IDs or agent names representing execution sequence",
      "items": {
        "type": "string"
      }
    },
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version (must be 1.0)"
    }
  },
  "required": ["sub_tasks", "task_sequence", "schema_version"],
  "additionalProperties": false,
  "allOf": [
    {
      "description": "Total effort across all sub_tasks must be >= 20 hours",
      "if": {
        "properties": {
          "sub_tasks": {
            "type": "array"
          }
        }
      },
      "then": {
        "properties": {
          "sub_tasks": {
            "type": "array"
          }
        }
      }
    }
  ]
}
