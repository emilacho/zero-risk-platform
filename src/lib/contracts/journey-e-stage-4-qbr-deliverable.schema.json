{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zero-risk-platform.vercel.app/schemas/journey-e-stage-4-qbr-deliverable.schema.json",
  "title": "Journey E Stage 4 — QBR Deliverable Output",
  "description": "Quarterly Business Review document generated by reporting-agent. Error E-015 enforces page count constraints",
  "type": "object",
  "properties": {
    "exec_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^(https://(supabase|storage\\.googleapis\\.com|s3\\.amazonaws\\.com)|gs://|s3://)",
      "description": "Cloud storage URL to executive summary PDF (must be accessible)"
    },
    "detail_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^(https://(supabase|storage\\.googleapis\\.com|s3\\.amazonaws\\.com)|gs://|s3://)",
      "description": "Cloud storage URL to detailed QBR report PDF (must be accessible)"
    },
    "recommendations": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "properties": {
          "recommendation": {
            "type": "string",
            "minLength": 20,
            "maxLength": 300,
            "description": "Specific recommendation for next quarter"
          },
          "effort": {
            "type": "string",
            "enum": ["low", "med", "high"],
            "description": "Implementation effort"
          },
          "estimated_impact": {
            "type": "string",
            "minLength": 10,
            "maxLength": 200,
            "description": "Expected impact (e.g., '15% revenue growth', '40% efficiency gain')"
          }
        },
        "required": ["recommendation", "effort", "estimated_impact"]
      },
      "description": "Must have exactly 3 recommendations"
    },
    "page_count": {
      "type": "object",
      "properties": {
        "executive": {
          "type": "integer",
          "const": 1,
          "description": "Executive summary must be exactly 1 page"
        },
        "detail": {
          "type": "integer",
          "minimum": 3,
          "maximum": 5,
          "description": "Detail section must be 3-5 pages (error E-015)"
        },
        "recommendations": {
          "type": "integer",
          "const": 1,
          "description": "Recommendations page must be exactly 1 page"
        }
      },
      "required": ["executive", "detail", "recommendations"],
      "additionalProperties": false
    },
    "generated_timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when QBR was generated"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    }
  },
  "required": ["exec_url", "detail_url", "recommendations", "page_count", "generated_timestamp", "schema_version"],
  "additionalProperties": false
}
