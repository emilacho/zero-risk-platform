{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zero-risk-platform.vercel.app/schemas/journey-c-phase-0-campaign-brief.schema.json",
  "title": "Journey C Phase 0 — Campaign Brief Output",
  "description": "Campaign brief generated by campaign-brief-agent with objectives, audience, channels, KPIs, and consultative inputs",
  "type": "object",
  "properties": {
    "objective": {
      "type": "string",
      "minLength": 30,
      "maxLength": 500,
      "description": "Campaign objective (specific, measurable, actionable)"
    },
    "target_audience": {
      "type": "object",
      "properties": {
        "description": {
          "type": "string",
          "minLength": 20,
          "maxLength": 300,
          "description": "Target audience profile description"
        },
        "segments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 5,
            "maxLength": 100
          },
          "description": "Audience segments (job title, company size, industry, etc.)"
        }
      },
      "required": ["description", "segments"],
      "additionalProperties": false
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "string",
        "enum": ["meta", "google", "email", "organic_social", "seo", "tiktok", "linkedin", "youtube", "organic_search"]
      },
      "description": "Channels to be used in campaign (min 1)"
    },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "type": "string",
        "minLength": 10,
        "maxLength": 200
      },
      "description": "Campaign deliverables (ads, landing pages, email sequences, etc.)"
    },
    "kpis": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 100,
            "description": "KPI name (e.g., ROAS, CTR, conversion rate)"
          },
          "target": {
            "oneOf": [
              { "type": "number" },
              { "type": "string" }
            ],
            "description": "Target value (numeric or string like '3.5x')"
          },
          "measurement": {
            "type": "string",
            "minLength": 5,
            "maxLength": 200,
            "description": "How KPI will be measured (GA4 event, UTM tracking, etc.)"
          }
        },
        "required": ["name", "target", "measurement"],
        "additionalProperties": false
      }
    },
    "timeline_weeks": {
      "type": "integer",
      "minimum": 1,
      "maximum": 52,
      "description": "Campaign duration in weeks"
    },
    "budget_daily": {
      "type": "number",
      "minimum": 1,
      "maximum": 999999,
      "description": "Daily budget allocation in USD"
    },
    "constraints": {
      "type": "object",
      "minProperties": 0,
      "description": "Any constraints (budget caps, blackout dates, channel restrictions, etc.)"
    },
    "consultative_inputs_applied": {
      "type": "object",
      "properties": {
        "media_buyer_recommendation": {
          "type": "string",
          "maxLength": 500,
          "description": "Recommendation from media-buyer agent (channel mix, budget strategy)"
        },
        "social_strategist_recommendation": {
          "type": "string",
          "maxLength": 500,
          "description": "Recommendation from social-media-strategist agent (platform mix, cadence)"
        },
        "seo_input": {
          "type": "string",
          "maxLength": 500,
          "description": "Recommendation from seo-specialist agent (keyword targeting)"
        },
        "market_timing": {
          "type": "string",
          "maxLength": 500,
          "description": "Market timing input from market-research agent (seasonality, trends)"
        }
      },
      "required": ["media_buyer_recommendation", "social_strategist_recommendation", "seo_input", "market_timing"],
      "additionalProperties": false
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    }
  },
  "required": ["objective", "target_audience", "channels", "deliverables", "kpis", "timeline_weeks", "budget_daily", "constraints", "consultative_inputs_applied", "schema_version"],
  "additionalProperties": false
}
