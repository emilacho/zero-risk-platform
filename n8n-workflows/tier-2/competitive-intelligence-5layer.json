{
  "name": "Zero Risk — Competitive Intelligence 5-Layer Deep Scan",
  "nodes": [
    {
      "parameters": { "httpMethod": "POST", "path": "zero-risk/ci-deep-scan", "responseMode": "responseNode", "options": {} },
      "id": "webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 380]
