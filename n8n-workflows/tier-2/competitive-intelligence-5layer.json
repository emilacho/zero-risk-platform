        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "Authorization", "value": "=Bearer {{ $env.FIRECRAWL_API_KEY }}" }, { "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={ \"url\": \"https://{{ $json.competitor_domain }}\", \"limit\": 80, \"scrapeOptions\": { \"formats\": [\"markdown\"], \"onlyMainContent\": true } }",
        "options": { "timeout": 300000, "response": { "response": { "neverError": true } } }
      },
      "id": "layer4-site", "name": "L4: Website Full Crawl", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [720, 500]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://google.serper.dev/news",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "X-API-KEY", "value": "={{ $env.SERPER_API_KEY }}" }, { "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={ \"q\": \"\\\"{{ $json.competitor_name }}\\\"\", \"tbs\": \"qdr:m\", \"num\": 30 }",
        "options": { "timeout": 30000, "response": { "response": { "neverError": true } } }
      },
