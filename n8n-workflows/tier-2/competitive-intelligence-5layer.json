        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={ \"companies\": [\"{{ $json.competitor_linkedin }}\"], \"maxPosts\": 30 }",
        "options": { "timeout": 180000, "response": { "response": { "neverError": true } } }
      },
      "id": "layer3-social", "name": "L3: LinkedIn + Social", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [720, 380]
