        "headerParameters": { "parameters": [{ "name": "Content-Type", "value": "application/json" }, { "name": "x-api-key", "value": "={{ $env.INTERNAL_API_KEY }}" }] },
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={\n  \"agent\": \"competitive_strategist\",\n  \"model\": \"claude-opus-4-6\",\n  \"task\": \"Synthesize 5-layer CI on {{ $node['validate'].json.competitor_name }} for client {{ $node['validate'].json.client_id }}. Layers: (1) Paid Ads — creative themes, hooks, offers, spend estimates. (2) SEO — top organic keywords, content gaps, ranking domains. (3) Social — cadence, formats, top performing posts, employee advocacy. (4) Website — value prop evolution, pricing, funnel design, CRO patterns. (5) PR/News — announcements, funding, leadership, sentiment.\\n\\nDeliver: strategic threat assessment, exploitable weaknesses, counter-moves our client should make this quarter, and a 'steal-this' list of tactical wins. Be specific, quote examples.\",\n  \"client_id\": \"{{ $node['validate'].json.client_id }}\",\n  \"extra\": {{ JSON.stringify($json) }}\n}",
        "options": { "timeout": 300000 }
      },
      "id": "strategist", "name": "Competitive Strategist (Opus)", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1280, 380]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.ZERO_RISK_API_URL }}/api/competitors/deep-report",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "Content-Type", "value": "application/json" }, { "name": "x-api-key", "value": "={{ $env.INTERNAL_API_KEY }}" }] },
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={\n  \"task_id\": \"{{ $node['validate'].json.task_id }}\",\n  \"client_id\": \"{{ $node['validate'].json.client_id }}\",\n  \"competitor_name\": \"{{ $node['validate'].json.competitor_name }}\",\n  \"raw\": {{ JSON.stringify($node['merge'].json) }},\n  \"synthesis\": {{ JSON.stringify($json) }}\n}",
        "options": {}
      },
      "id": "persist", "name": "Persist Deep Report", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1560, 380]
    },
