    {
      "parameters": {
        "jsCode": "const b = $input.first().json.body || $input.first().json;\nif (!b.client_id || !b.competitor_name) throw new Error('client_id and competitor_name required');\nreturn [{ json: {\n  task_id: `ci_${Date.now()}`,\n  client_id: b.client_id,\n  competitor_name: b.competitor_name,\n  competitor_domain: b.competitor_domain || null,\n  competitor_meta_id: b.competitor_meta_id || null,\n  competitor_linkedin: b.competitor_linkedin || null,\n  industry: b.industry || null\n} }];"
      },
      "id": "validate", "name": "Validate", "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [440, 380]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/apify~facebook-ads-library-scraper/run-sync-get-dataset-items?token={{ $env.APIFY_TOKEN }}&timeout=120",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "={ \"searchTerms\": [\"{{ $json.competitor_name }}\"], \"adActiveStatus\": \"all\", \"countryCode\": \"US\", \"maxItems\": 50 }",
        "options": { "timeout": 180000, "response": { "response": { "neverError": true } } }
      },
      "id": "layer1-meta", "name": "L1: Meta Ad Library", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [720, 140]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.dataforseo.com/v3/dataforseo_labs/google/competitors_domain/live",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "Authorization", "value": "=Basic {{ $env.DATAFORSEO_AUTH }}" }, { "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true, "specifyBody": "json",
        "jsonBody": "=[{ \"target\": \"{{ $json.competitor_domain }}\", \"location_code\": 2840, \"language_code\": \"en\", \"limit\": 100 }]",
        "options": { "timeout": 60000, "response": { "response": { "neverError": true } } }
      },
      "id": "layer2-seo", "name": "L2: DataForSEO Competitors", "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [720, 260]
    },
    {
      "parameters": {
        "method": "POST",
