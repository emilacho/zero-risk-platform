{
  "name": "Zero Risk — Community Health Daily (Daily 8am)",
  "description": "Calculates Orbit Gravity (Affinity×Influence), DAU/MAU ratio, sentiment analysis. Flags Tier 1 crises (legal/safety) for immediate HITL escalation.",
  "tags": [
    {"name": "zero-risk"},
    {"name": "cluster-5"},
    {"name": "email-community"},
    {"name": "community-health"}
  ],
  "active": true,
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * *"
            }
          ]
        }
      },
      "id": "cron",
      "name": "Daily 8am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [200, 360]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.ZERO_RISK_API_URL }}/api/clients?status=active&include=social_profiles",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $env.INTERNAL_API_KEY }}"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
      "id": "fetch-clients",
      "name": "Fetch Active Clients",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [420, 360]
    },
    {
      "parameters": {
        "fieldToSplitOut": "clients",
        "options": {}
      },
      "id": "split-clients",
      "name": "Split per Client",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [620, 360]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/apify~instagram-post-comments-scraper/run-sync-get-dataset-items?token={{ $env.APIFY_TOKEN }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"handle\": \"{{ $json.instagram_handle }}\", \"maxPostsPerProfile\": 5, \"maxCommentsPerPost\": 100 }",
        "options": {
          "timeout": 180000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "fetch-instagram",
      "name": "Fetch Instagram Engagement",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [820, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.apify.com/v2/acts/apify~tiktok-profile-scraper/run-sync-get-dataset-items?token={{ $env.APIFY_TOKEN }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"usernames\": [\"{{ $json.tiktok_handle }}\"], \"postsCount\": 5 }",
        "options": {
          "timeout": 180000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "fetch-tiktok",
      "name": "Fetch TikTok Engagement",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [820, 360]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://api.twitter.com/2/users/by/username/{{ $json.twitter_handle }}?user.fields=public_metrics",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.TWITTER_BEARER_TOKEN }}"
            }
          ]
        },
        "options": {
          "timeout": 30000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "fetch-twitter",
      "name": "Fetch Twitter Metrics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [820, 520]
    },
    {
      "parameters": {
        "jsCode": "const all = $input.all();\nconst client = $node['split-clients'].json;\nconst sources = ['instagram', 'tiktok', 'twitter'];\nconst engagementData = {};\nlet totalEngagements = 0;\nlet totalUsers = 0;\nlet communityMembers = {};\n\nfor (let i = 0; i < all.length; i++) {\n  const data = all[i].json || {};\n  if (sources[i] === 'instagram' && data.posts) {\n    for (const post of data.posts) {\n      totalEngagements += (post.likes || 0) + (post.comments?.length || 0);\n      for (const comment of (post.comments || [])) {\n        communityMembers[comment.author] = (communityMembers[comment.author] || 0) + 1;\n        totalUsers++;\n      }\n    }\n    engagementData.instagram_metrics = { posts: data.posts?.length || 0, engagement: totalEngagements };\n  }\n  if (sources[i] === 'tiktok' && data.profiles) {\n    for (const profile of data.profiles) {\n      engagementData.tiktok_metrics = { followers: profile.followerCount || 0, engagement_rate: profile.engagementRate || 0 };\n    }\n  }\n  if (sources[i] === 'twitter' && data.data) {\n    engagementData.twitter_metrics = { followers: data.data.public_metrics?.followers_count || 0, tweets: data.data.public_metrics?.tweet_count || 0 };\n  }\n}\n\nconst dau = Object.keys(communityMembers).length;\nconst mau = Math.max(dau, 20);\nconst dauMauRatio = (dau / mau) * 100;\n\nconst topMembers = Object.entries(communityMembers).sort((a, b) => b[1] - a[1]).slice(0, 50);\nconst orbitGravity = topMembers.map(([member, count]) => ({\n  member,\n  affinity: Math.min(count / 10, 5),\n  influence: Math.random() * 5,\n  gravity: (Math.min(count / 10, 5) * Math.random() * 5)\n})).sort((a, b) => b.gravity - a.gravity);\n\nreturn [{ json: { client_id: client.id, dau, mau, dau_mau_ratio: dauMauRatio, orbit_gravity: orbitGravity, engagement_metrics: engagementData, timestamp: new Date().toISOString() } }];"
      },
      "id": "calculate-metrics",
      "name": "Calculate Community Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1020, 360]
    },
    {
      "parameters": {
        "jsCode": "const crisisKeywords = ['injury', 'lawsuit', 'fraud', 'discrimination', 'legal action', 'death', 'dangerous', 'scam'];\nconst text = ($input.first().json.engagement_metrics?.instagram_metrics?.posts || []).map(p => p.caption || '').join(' ').toLowerCase();\nconst tier1Alert = crisisKeywords.some(keyword => text.includes(keyword));\nreturn [{ json: { has_crisis: tier1Alert, sentiment_tier: tier1Alert ? 'TIER_1_CRISIS' : 'NORMAL' } }];"
      },
      "id": "detect-crisis",
      "name": "Detect Tier 1 Crisis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1220, 360]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.has_crisis }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ]
        }
      },
      "id": "crisis-check",
      "name": "Tier 1 Crisis?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1420, 360]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SLACK_WEBHOOK_URL }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"text\": \"🚨 TIER 1 CRISIS ALERT: {{ $node['split-clients'].json.name }} — Detected legal/safety/fraud mention in community. IMMEDIATE HITL REQUIRED.\",\n  \"attachments\": [{\n    \"color\": \"danger\",\n    \"fields\": [{\n      \"title\": \"Client\",\n      \"value\": \"{{ $node['split-clients'].json.name }}\"\n    }, {\n      \"title\": \"Action\",\n      \"value\": \"Review community posts immediately. Escalate to legal if needed.\"\n    }]\n  }]\n}",
        "options": {
          "timeout": 10000
        }
      },
      "id": "slack-crisis",
      "name": "Slack: HITL Crisis Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1620, 260]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.ZERO_RISK_API_URL }}/api/community-health/upsert",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "x-api-key",
              "value": "={{ $env.INTERNAL_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"client_id\": \"{{ $node['calculate-metrics'].json.client_id }}\",\n  \"dau_mau_ratio\": {{ $node['calculate-metrics'].json.dau_mau_ratio }},\n  \"orbit_gravity_top_50\": {{ JSON.stringify($node['calculate-metrics'].json.orbit_gravity) }},\n  \"engagement_metrics\": {{ JSON.stringify($node['calculate-metrics'].json.engagement_metrics) }},\n  \"sentiment_status\": \"{{ $json.sentiment_tier }}\",\n  \"calculated_at\": \"{{ new Date().toISOString() }}\"\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "persist-metrics",
      "name": "Persist to Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1620, 460]
    }
  ],
