{
  "name": "Zero Risk — Email Lifecycle Orchestrator (Webhook-Driven)",
  "description": "Routes contacts through 5-flow lifecycle: welcome, abandoned cart, post-purchase, browse abandonment, winback. Calls Email Marketer agent for copy with Schwedelson patterns.",
  "tags": [
    {"name": "zero-risk"},
    {"name": "cluster-5"},
    {"name": "email-community"},
    {"name": "lifecycle-email"}
