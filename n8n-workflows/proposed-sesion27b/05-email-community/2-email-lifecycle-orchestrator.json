      "parameters": {
        "httpMethod": "POST",
        "path": "zero-risk/email-lifecycle",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook",
      "name": "Webhook: Lifecycle Event",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 360]
    },
    {
      "parameters": {
        "jsCode": "const b = $input.first().json.body || $input.first().json;\nconst validEvents = ['contact_created', 'cart_abandoned', 'purchase_completed', 'browse_abandoned', 'inactivity_180d'];\nif (!validEvents.includes(b.event_type) || !b.client_id || !b.contact_id) throw new Error('Invalid event_type, client_id, or contact_id');\nreturn [{ json: { event_type: b.event_type, client_id: b.client_id, contact_id: b.contact_id, contact_email: b.contact_email, extra: b } }];"
      },
      "id": "validate",
      "name": "Validate Event",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 360]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.event_type }}",
              "rightValue": "contact_created",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ]
        }
      },
      "id": "route-welcome",
