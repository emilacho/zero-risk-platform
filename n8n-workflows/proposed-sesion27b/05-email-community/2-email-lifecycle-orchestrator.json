        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"agent\": \"email_marketer\",\n  \"model\": \"claude-sonnet-4-6\",\n  \"task\": \"Design Welcome Series (3 emails, 1-7 day cadence). Use Jay Schwedelson patterns: numerals in subject (+19%), 3-word short format (+25%), emoji testing (+17%). Return 3 emails: { subject_a, subject_b, preview_text, mjml_body, plain_text, send_day }. Personalize with {{first_name}}.\",\n  \"client_id\": \"{{ $json.client_id }}\",\n  \"extra\": {{ JSON.stringify($json) }}\n}",
        "options": {
          "timeout": 120000
        }
      },
