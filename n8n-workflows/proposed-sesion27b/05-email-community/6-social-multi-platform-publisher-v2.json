      "id": "split-content",
      "name": "Split per Content",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [620, 300]
    },
    {
      "parameters": {
        "jsCode": "const pillar = $json.pillar_topic || 'General';\nconst baseText = $json.caption || $json.text || '';\nconst platforms = ['linkedin', 'twitter', 'instagram', 'tiktok'];\nconst adaptations = {};\n\nfor (const platform of platforms) {\n  let adapted = baseText;\n  const platformLimits = { linkedin: 3000, twitter: 280, instagram: 2200, tiktok: 2200 };\n  \n  if (platform === 'linkedin') {\n    adapted = adapted.length > 300 ? adapted.substring(0, 300) + '...' : adapted;\n    adapted += `\\n\\n#${pillar.replace(/\\s+/g, '')} #B2B #ThoughtLeadership`;\n  } else if (platform === 'twitter') {\n    adapted = adapted.substring(0, 250);\n    adapted += ` #${pillar.replace(/\\s+/g, '')}`;\n  } else if (platform === 'instagram') {\n    adapted = adapted.substring(0, 2000);\n    adapted += `\\n\\n#${pillar.replace(/\\s+/g, '')} #marketing #community`;\n  } else if (platform === 'tiktok') {\n    adapted = adapted.substring(0, 2000);\n    adapted = adapted.toLowerCase();\n    adapted += ` #${pillar.toLowerCase().replace(/\\s+/g, '')} #trending`;\n  }\n  \n  adaptations[platform] = adapted;\n}\n\nreturn [{ json: { ...adaptations, original: baseText, platforms_ready: platforms } }];"
      },
      "id": "adapt-platforms",
      "name": "Adapt per Platform",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [820, 300]
    },
    {
      "parameters": {
        "jsCode": "const platforms = $json.platforms_ready || ['linkedin', 'twitter', 'instagram', 'tiktok'];\nreturn platforms.map(p => ({ json: { platform: p, content: $json[p], media_url: $json.media_url } }));"
      },
      "id": "split-platforms",
      "name": "Split per Platform",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [1020, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.linkedin.com/v2/ugcPosts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.LINKEDIN_ACCESS_TOKEN }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"author\": \"urn:li:person:{{ $env.LINKEDIN_PERSON_ID }}\",\n  \"lifecycleState\": \"PUBLISHED\",\n  \"specificContent\": {\n    \"com.linkedin.ugc.UGCContent\": {\n      \"shareContent\": {\n        \"shareCommentary\": { \"text\": \"{{ $json.content }}\" },\n        \"shareMediaCategory\": \"IMAGE\",\n        \"media\": [{ \"status\": \"READY\", \"description\": { \"text\": \"Content\" }, \"media\": \"urn:li:digitalmediaAsset:{{ $env.LINKEDIN_ASSET_ID }}\" }]\n      }\n    }\n  },\n  \"visibility\": { \"com.linkedin.ugc.MemberNetworkVisibility\": \"PUBLIC\" }\n}",
        "options": {
          "timeout": 30000,
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
