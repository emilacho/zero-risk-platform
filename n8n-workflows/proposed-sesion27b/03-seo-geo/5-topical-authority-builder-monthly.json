{
  "name": "Zero Risk — SEO Topical Authority Builder Monthly",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 3 1 * *"
            }
          ]
        }
      },
      "id": "trigger-9UYoXt",
      "name": "Trigger: 1st of month 3am UTC",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const resp = await fetch('https://zero-risk-platform.vercel.app/api/clients?active=true', { headers: { 'x-api-key': 'key' } });\nconst data = await resp.json();\nreturn [{ json: { clients: Array.isArray(data) ? data : (data.clients ?? data.rows ?? []) } }];"
      },
      "id": "load-clients-9UYoXt",
      "name": "Load Active Clients",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
      "parameters": {
        "fieldToSplitOut": "clients"
      },
      "id": "split-9UYoXt",
      "name": "Split Into Each Client",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.ZERO_RISK_API_URL || \"https://zero-risk-platform.vercel.app\" }}/api/agents/run",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $env.INTERNAL_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  agent_name: \"seo-content-strategist\",\n  client_id: $json.client_id || $json.id || null,\n  task_input: {\n    client_id: $json.client_id || $json.id,\n    client_name: $json.client_name || $json.name,\n    vertical: $json.vertical || $json.industry,\n    domain: $json.domain || null,\n    target_keyword: $json.target_keyword || null,\n    locale: $json.locale || { country: \"US\", language: \"en\" },\n    cron_run_at: new Date().toISOString()\n  }, workflow_id: $workflow.id, workflow_execution_id: $execution.id }) }}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "invoke-9UYoXt",
      "name": "Invoke seo-content-strategist",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.ZERO_RISK_API_URL || \"https://zero-risk-platform.vercel.app\" }}/api/cascade/persist-outputs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{ $env.INTERNAL_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  client_id: ($node[\"Split Into Each Client\"].json.client_id || $node[\"Split Into Each Client\"].json.id),\n  slug: ($node[\"Split Into Each Client\"].json.slug || $node[\"Split Into Each Client\"].json.client_id || \"unknown\"),\n  version: \"topical-authority-\" + new Date().toISOString().slice(0, 10),\n  task_id: \"topical-authority-cron-\" + Date.now(),\n  outputs: {\n    \"seo-content-strategist\": $json\n  }\n}) }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "persist-9UYoXt",
      "name": "Persist Deliverable",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1120,
        300
      ],
      "continueOnFail": true
    }
  ],
  "connections": {
    "Trigger: 1st of month 3am UTC": {
      "main": [
        [
          {
            "node": "Load Active Clients",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Load Active Clients": {
      "main": [
        [
          {
            "node": "Split Into Each Client",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Split Into Each Client": {
      "main": [
        [
          {
            "node": "Invoke seo-content-strategist",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Invoke seo-content-strategist": {
      "main": [
        [
          {
            "node": "Persist Deliverable",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "callerPolicy": "workflowsFromSameOwner",
    "availableInMCP": false
  },
  "tags": [],
  "triggerCount": 1,
  "versionId": "3cbd8f7d-150e-463e-9d4c-ff379c31c7f3"
}
