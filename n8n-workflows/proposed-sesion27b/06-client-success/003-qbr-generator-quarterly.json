        "specifyBody": "json",
        "jsonBody": "={\n  \"agent_id\": \"reporting-agent\",\n  \"task\": \"Generate QBR narrative with SCQA + McKinsey pyramid for {{ $json.client_name }} (Tier {{ $json.engagement_tier }}). Last 90d outcomes: ROAS={{ $json.roas }}, leads={{ $json.leads_generated }}, pipeline_value={{ $json.pipeline_value }}. Targets: ROAS_target={{ $json.kpi_roas_target }}, leads_target={{ $json.kpi_leads_target }}. Industry benchmarks: median_roas={{ $json.benchmark_median_roas }}, 75th_percentile={{ $json.benchmark_75th_roas }}. Include executive brief (SCQA), KPI dashboard, channel breakdown, benchmarking, recommendations.\",\n  \"workflow_id\": \"{{ $workflow.id }}\",\n  \"workflow_execution_id\": \"{{ $execution.id }}\",\n  \"context\": {{ JSON.stringify($json) }}\n}",
        "options": {
          "timeout": 120000
        }
