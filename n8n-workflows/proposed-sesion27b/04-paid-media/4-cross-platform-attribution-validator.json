      "name": "Split",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [660, 320]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.ZERO_RISK_API_URL || 'https://zero-risk-platform.vercel.app' }}/api/meta-ads/spend-data?campaign_id={{ $json.id }}&hours=1",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{"name": "x-api-key", "value": "={{ $env.INTERNAL_API_KEY }}"}]
        },
        "options": {"timeout": 20000, "response": {"response": {"neverError": true}}}
      },
      "id": "meta-spend",
      "name": "Meta Spend + Conversions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
