          "conditions": [
            {
              "leftValue": "={{ Number($('Editor en Jefe (Sonnet) - Schwartz Audit').item.json.match_score) || 100 }}",
              "rightValue": 70,
              "operator": {
                "type": "number",
                "operation": "lt"
              }
            }
          ]
        }
      },
