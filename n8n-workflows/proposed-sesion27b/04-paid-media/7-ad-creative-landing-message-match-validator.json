        "jsonBody": "={\n  \"text\": {{ JSON.stringify('Message Match Violation: ' + ($('Validate Input').item.json.campaign_id || 'unknown')) }},\n  \"blocks\": [\n    {\n      \"type\": \"section\",\n      \"text\": { \"type\": \"mrkdwn\", \"text\": {{ JSON.stringify('*MESSAGE MATCH VIOLATION DETECTED*\\nCampaign: ' + ($('Validate Input').item.json.campaign_id || 'unknown') + '\\nMatch Score: ' + (Number($('Editor en Jefe (Sonnet) - Schwartz Audit').item.json.match_score) || 0) + '/100\\n\\nRequired Actions:\\n' + (($('Editor en Jefe (Sonnet) - Schwartz Audit').item.json.required_actions || []).map(a => '- ' + a).join('\\n')) + '\\n\\nAd launch BLOCKED pending fixes.') }} }\n    }\n  ]\n}",
        "options": {
