    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.ZERO_RISK_API_URL || 'https://zero-risk-platform.vercel.app' }}/api/agents/run",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "x-api-key",
              "value": "={{ $env.INTERNAL_API_KEY }}"
            },
            {
              "name": "x-smoke-test",
              "value": "={{ ($('Validate Input').item.json.client_id || \"\").startsWith(\"smoke-\") ? \"1\" : \"\" }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"agent\": \"editor-en-jefe\",\n  \"model\": \"claude-sonnet-4-6\",\n  \"task\": {{ JSON.stringify('Message-match audit for campaign ' + ($('Validate Input').item.json.campaign_id || 'unknown') + '. Apply Schwartz positioning layers and score 0-100. If >30pt mismatch, flag and recommend copy/positioning fixes. Return JSON: { match_score, flags, required_actions }.') }},\n  \"client_id\": \"{{ $('Validate Input').item.json.client_id || '' }}\",\n  \"audit_id\": \"{{ $('Validate Input').item.json.audit_id || '' }}\",\n  \"campaign_id\": {{ JSON.stringify($('Validate Input').item.json.campaign_id ?? null) }},\n  \"creative_id\": {{ JSON.stringify($('Validate Input').item.json.creative_id ?? null) }},\n  \"landing_url\": {{ JSON.stringify($('Validate Input').item.json.landing_url ?? null) }},\n  \"change_type\": {{ JSON.stringify($('Validate Input').item.json.change_type ?? null) }},\n  \"workflow_id\": \"{{ $workflow.id }}\",\n  \"workflow_execution_id\": \"{{ $execution.id }}\",\n  \"context\": { \"smoke_test\": {{ ($('Validate Input').item.json.client_id || \"\").startsWith(\"smoke-\") }} },\n  \"extra\": { \"validate_input\": {{ JSON.stringify($('Validate Input').item.json ?? {}) }}, \"merged_content\": {{ JSON.stringify($json ?? {}) }} }\n}",
        "options": {
          "timeout": 180000
        }
      },
      "id": "editor-audit",
      "name": "Editor en Jefe (Sonnet) - Schwartz Audit",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1200,
        320
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose"
