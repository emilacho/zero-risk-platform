        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contact_id\": \"{{ $json.contact_id }}\",\n  \"tag\": \"nurture\"\n}",
        "options": {}
      },
      "id": "ghl-nurture",
      "name": "GHL Tag: Nurture",
