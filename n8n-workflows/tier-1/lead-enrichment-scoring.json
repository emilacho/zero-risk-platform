        "jsonBody": "={\n  \"text\": \"🎯 Lead scored\\n• Email: {{ $node['Score Lead'].json.email }}\\n• Score: {{ $node['Score Lead'].json.score }} ({{ $node['Score Lead'].json.bucket }})\\n• Company: {{ $node['Score Lead'].json.company }}\\n• Title: {{ $node['Score Lead'].json.enrichment.title }}\"\n}",
        "options": {}
