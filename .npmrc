# Constrain which optional platform packages pnpm installs for this project
# (Vercel build host). Without this, pnpm pulls both linux-x64-glibc AND
# linux-x64-musl variants for any package that ships native binaries; the
# SDK's runtime resolution then sometimes picks musl, which Vercel functions
# (Amazon Linux 2 · glibc) can't execute.
#
# Note: as of this commit the Vercel side no longer uses
# @anthropic-ai/claude-agent-sdk directly (the SDK runtime lives in the
# Railway service services/agent-runner/, see fix(vercel): wire ... reverse
# proxy ... · 962f621). This config remains as defense-in-depth in case any
# future dep ships native binaries with similar musl/glibc fan-out.
supportedArchitectures.os[]=linux
supportedArchitectures.cpu[]=x64
supportedArchitectures.libc[]=glibc
