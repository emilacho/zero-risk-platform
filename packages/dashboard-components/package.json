{
  "name": "@zero-risk/dashboard-components",
  "version": "0.1.0",
  "private": true,
  "description": "Tremor-style data-viz + ReactFlow memory-graph components for the Zero Risk Mission Control dashboard. Prepped in parallel with the CC#1 scaffold — ready to integrate when the dashboard host lands.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme/index.ts",
