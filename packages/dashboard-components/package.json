    "./memory-graph": "./src/memory-graph/index.ts"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.0",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "tremor",
    "reactflow",
    "dashboard",
    "zero-risk",
    "mission-control"
  ]
