# Zero Risk V2 — Environment Variables
# Copy to .env.local and fill in values

# Supabase (Layer 4: Backend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API (Layer 1: AI Agents)
# IMPORTANT: code uses CLAUDE_API_KEY, not ANTHROPIC_API_KEY
CLAUDE_API_KEY=your-claude-api-key

# Composio (Layer 1: AI Agent Execution)
COMPOSIO_API_KEY=your-composio-key

# Ideogram v3 (Image Generation)
IDEOGRAM_API_KEY=your-ideogram-key

# Mailgun (Email Marketing)
MAILGUN_API_KEY=your-mailgun-key
MAILGUN_DOMAIN=your-domain.com

# n8n (Layer 2: Orchestration · self-hosted Railway)
N8N_BASE_URL=https://your-n8n-instance.up.railway.app
N8N_API_KEY=your-n8n-jwt-token
# Optional · per-workflow webhook overrides (full URLs)
# N8N_AGENT_PIPELINE_WEBHOOK=https://your-n8n-instance.up.railway.app/webhook/agent-pipeline

# GoHighLevel (CRM)
GHL_API_KEY=your-ghl-key

# App Config
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
