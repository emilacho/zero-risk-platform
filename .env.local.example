# Zero Risk · Environment Variables (Stack V4 · canon 2026-05-22)
# Copy to .env.local and fill in values.
#
# Single source of truth · zr-vault/wiki/decisions/2026-05-22-stack-canon-purge-deprecated-services-audit.md
# Deprecated services purged 2026-05-22 · Composio · Mailgun · Ideogram · Kling · GHL · Higgsfield · GA4 · GTM.

# ────────────────────────────────────────────────────────────────────
# CORE INFRASTRUCTURE
# ────────────────────────────────────────────────────────────────────

# Supabase (Layer 4: Backend · DB + Auth + Storage + pgvector)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=your-supabase-management-api-pat

# Claude API (Layer 1: AI Agents)
# IMPORTANT · code uses CLAUDE_API_KEY · not ANTHROPIC_API_KEY
# Vercel side only needs this for legacy /api/agents/run · SDK runtime lives on Railway.
CLAUDE_API_KEY=your-claude-api-key

# Railway agent-runner (Layer 1: AI Agents · SDK runtime)
# @anthropic-ai/claude-agent-sdk ships a 219.9MB linux-x64 native binary that
# Vercel NFT cannot bundle · runner lives on dedicated Railway service.
RAILWAY_AGENT_RUNNER_URL=https://zero-risk-agent-runner-production.up.railway.app

# Internal shared secret · BOTH hops:
#   1. caller (n8n, scripts) → Vercel /api/agents/run-sdk     (x-api-key header)
#   2. Vercel proxy → Railway agent-runner /run-sdk            (x-internal-auth header)
INTERNAL_API_KEY=your-internal-api-key

# n8n (Layer 2: Orchestration · self-hosted Railway)
N8N_BASE_URL=https://your-n8n-instance.up.railway.app
N8N_API_KEY=your-n8n-jwt-token

# ────────────────────────────────────────────────────────────────────
# STACK V4 CANONICAL OUTBOUND CHANNELS
# ────────────────────────────────────────────────────────────────────

# Email · Resend (~$20/mo pay-as-grow · GHL/Mailgun OUT)
RESEND_API_KEY=your-resend-key
RESEND_FROM_EMAIL=hello@your-domain.com

# SMS · Twilio (pay-per-use · canonical SMS provider)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1234567890

# WhatsApp · Meta Cloud API v21 directo (no BSP)
WHATSAPP_PHONE_NUMBER_ID=your-meta-phone-id
WHATSAPP_ACCESS_TOKEN=your-meta-system-user-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token
META_APP_SECRET=your-meta-app-secret

# Cal.com · self-host Railway (canonical calendar · GHL Calendar OUT)
CAL_COM_API_KEY=your-cal-com-key
CAL_COM_BASE_URL=https://cal-com-production-e55b.up.railway.app

# Tally · forms webhook (canonical forms intake · GHL Forms OUT)
TALLY_SIGNING_SECRET=your-tally-signing-secret

# Notion · reports + Brand Books (canonical reporting via API)
NOTION_API_KEY=your-notion-integration-key
NOTION_PARENT_PAGE_ID=your-parent-page-id

# ────────────────────────────────────────────────────────────────────
# AD PLATFORMS (APIs directas · NO Composio)
# ────────────────────────────────────────────────────────────────────

# Meta Ads (Facebook Developers App · System User Token directo)
META_ACCESS_TOKEN=your-meta-system-user-token
META_FB_PAGE_ID=your-fb-page-id
META_IG_BUSINESS_ACCOUNT_ID=your-ig-business-id

# ────────────────────────────────────────────────────────────────────
# ANALYTICS (Stack V4 · PostHog only · GA4/GTM OUT)
# ────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_POSTHOG_KEY=your-posthog-public-key
POSTHOG_PROJECT_ID=your-posthog-project-id
POSTHOG_PERSONAL_API_KEY=your-posthog-personal-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ────────────────────────────────────────────────────────────────────
# DATA + INTELLIGENCE
# ────────────────────────────────────────────────────────────────────

# Apify (Competitive Intelligence scrapers · pay-per-run)
APIFY_TOKEN=your-apify-token

# DataForSEO (SEO data · pay-per-use $0.0006/SERP)
DATAFORSEO_LOGIN=your-dataforseo-login
DATAFORSEO_PASSWORD=your-dataforseo-password

# OpenAI (Whisper transcription · GPT Image 1.5 fallback)
OPENAI_API_KEY=your-openai-key

# ────────────────────────────────────────────────────────────────────
# MONITORING
# ────────────────────────────────────────────────────────────────────

SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
HEALTHCHECKS_BASE_URL=https://hc-ping.com

# ────────────────────────────────────────────────────────────────────
# APP CONFIG
# ────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
ZERO_RISK_API_URL=https://zero-risk-platform.vercel.app
